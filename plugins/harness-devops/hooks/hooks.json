{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/load-harness.sh devops" }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/cosign-tlog-required.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/kubectl-context-guard.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/plan-before-apply.sh" }
        ]
      }
    ]
  }
}
