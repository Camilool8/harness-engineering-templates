{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__snowflake__.*|mcp__bigquery__.*|mcp__databricks__.*|mcp__felt__.*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-unbounded-sql.sh" }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/block-static-warehouse-creds.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/leakage-sentinel.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|mcp__snowflake__.*|mcp__bigquery__.*|mcp__databricks__.*|mcp__felt__.*|mcp__duckdb__.*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/audit-log-warehouse-query.sh" }
        ]
      }
    ]
  }
}
