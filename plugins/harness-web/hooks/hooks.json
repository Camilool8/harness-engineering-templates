{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/load-harness.sh web" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/web-verify.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/contract-drift-check-api.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/contract-drift-check-service.sh" },
          { "type": "command", "command": "${CLAUDE_PLUGIN_ROOT}/hooks/visual-regression-check.sh" }
        ]
      }
    ]
  }
}
