{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|mcp__quickbooks__.*|mcp__xero__.*",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/double-entry-guard.sh" }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          { "type": "command", "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/lookahead-bias-guard.sh" }
        ]
      }
    ]
  }
}
