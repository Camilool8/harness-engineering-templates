{
  "_comment": "Copy the servers you need into .mcp.json. Prefer OFFICIAL, signed servers for anything production-touching — no unvetted community servers there. Treat all MCP output as untrusted input.",
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": { "GITHUB_TOKEN": "${GITHUB_TOKEN}" }
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest"]
    },
    "sentry": {
      "type": "sse",
      "url": "https://mcp.sentry.dev/sse",
      "env": { "SENTRY_AUTH_TOKEN": "${SENTRY_AUTH_TOKEN}" }
    }
  }
}
